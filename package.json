{
  "name": "contextura",
  "version": "0.7.0",
  "description": "Editor nativo para gestionar contextos organizacionales en markdown. Historial, diffs inline estilo Google Docs y live reload.",
  "author": "Entaina",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "desktop": "electron .",
    "dist": "electron-builder",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "node --test 'test/unit/**/*.test.mjs' 'test/unit/**/*.test.cjs'",
    "test:integration": "node --test 'test/integration/**/*.test.mjs' 'test/integration/**/*.test.cjs'",
    "test:e2e": "playwright test",
    "test:ci": "npm run test:unit && npm run test:integration"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Entaina/contextura.git"
  },
  "homepage": "https://github.com/Entaina/contextura",
  "bugs": {
    "url": "https://github.com/Entaina/contextura/issues"
  },
  "dependencies": {
    "chokidar": "^3"
  },
  "devDependencies": {
    "@doyensec/electronegativity": "^1.10.3",
    "@playwright/test": "^1.59.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "eslint": "^9",
    "globals": "^15.15.0",
    "lefthook": "^2.1.5",
    "neostandard": "^0.12.2"
  },
  "overrides": {
    "tar": "^7.5.13"
  }
}
